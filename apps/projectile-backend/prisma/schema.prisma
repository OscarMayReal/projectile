// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  generatedFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  name                  String
  userConnectionId      String
  accountConnectionType AccountConnectionType @default(KeyStone)
  projectPermissions    ProjectPermission[]
  createdBoards         Board[] @relation("BoardToCreator")
  assignedTasks         AssignedTask[] @relation("UserToAssigned")
  comments              TaskComment[] @relation("UserToComment")
  createdTasks          Task[] @relation("TaskToCreator")
  @@unique([userConnectionId, accountConnectionType])
}

model ProjectPermission {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id])
  projectId String
  project Project @relation(fields: [projectId], references: [id], name: "ProjectToPermission")
  permissionLevel ProjectPermissionLevel
}

model Project {
  id String @id @default(uuid())
  name String
  permissions ProjectPermission[] @relation("ProjectToPermission")
  boards Board[] @relation("ProjectToBoard")
}

model Board {
  iconName String?
  color String? @default("#0c9d6d")
  id String @id @default(uuid())
  name String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  description String?
  createdBy String
  creatorUser User @relation(fields: [createdBy], references: [id], name: "BoardToCreator")
  states State[]
  project Project @relation(fields: [projectId], references: [id], name: "ProjectToBoard")
  projectId String
}

model State {
  id String @id @default(uuid())
  boardId String
  board Board @relation(fields: [boardId], references: [id])
  name String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  type StateType @default(Open)
  color String @default("#6b7280")
  tasks Task[] @relation("StateToTask")
}

model Task {
  id String @id @default(uuid())
  stateId String
  state State @relation(fields: [stateId], references: [id], name: "StateToTask")
  name String
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assignedTasks AssignedTask[] @relation("TaskToAssigned")
  comments TaskComment[] @relation("TaskToComment")
  createdBy String
  creatorUser User @relation(fields: [createdBy], references: [id], name: "TaskToCreator")
}

model TaskComment {
  id String @id @default(uuid())
  taskId String
  task Task @relation(fields: [taskId], references: [id], name: "TaskToComment")
  userId String
  user User @relation(fields: [userId], references: [id], name: "UserToComment")
  content String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssignedTask {
  id String @id @default(uuid())
  taskId String
  task Task @relation(fields: [taskId], references: [id], name: "TaskToAssigned")
  userId String
  user User @relation(fields: [userId], references: [id], name: "UserToAssigned")
}

enum AccountConnectionType {
  KeyStone
}

enum ProjectPermissionLevel {
  Read
  Member
  Admin
}

enum StateType {
  PreOpen
  Open
  Blocked
  InProgress
  Ready
  Done
  Closed
}